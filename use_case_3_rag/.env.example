# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Neo4j (defaults to in-memory NetworkX graph if not set)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Optional: tune these
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_SEMANTIC=5
TOP_K_KEYWORD=5
TOP_K_GRAPH=3
RERANK_TOP_N=6
